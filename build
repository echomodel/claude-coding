#!/usr/bin/env python3
"""Build script for claude-coding-plugin.

Vendors skills from external marketplaces into the plugin's skills/
directory. Source of truth for vendored skills is the marketplace repo;
this plugin tracks copies that are synced at build time.

Usage: ./build
"""

import configparser
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

PLUGIN_ROOT = Path(__file__).resolve().parent
SKILLS_DIR = PLUGIN_ROOT / "skills"

# Skills native to this plugin — never overwritten by build.
NATIVE_SKILLS = {
    "publish-pull-request",
    "privacy-scan",
    "delegate-refactoring",
    "check-feature-support",
}


def load_config():
    cfg = configparser.ConfigParser()
    cfg.read(PLUGIN_ROOT / "build.cfg")
    return cfg


def sync_marketplace(name, url, ref, skill_paths):
    """Clone a marketplace repo and copy listed skills into skills/."""
    with tempfile.TemporaryDirectory() as tmp:
        print(f"\n[{name}] Cloning {url} (ref: {ref})...")
        result = subprocess.run(
            ["git", "clone", "--depth", "1", "--branch", ref, url, tmp],
            capture_output=True, text=True,
        )
        if result.returncode != 0:
            print(f"  FAILED: {result.stderr.strip()}", file=sys.stderr)
            sys.exit(1)

        synced = 0
        for skill_path in skill_paths:
            skill_path = skill_path.strip()
            if not skill_path:
                continue

            skill_name = Path(skill_path).name
            src = Path(tmp) / skill_path / "SKILL.md"
            dst = SKILLS_DIR / skill_name / "SKILL.md"

            if skill_name in NATIVE_SKILLS:
                print(f"  SKIP {skill_name} (native)")
                continue

            if not src.exists():
                print(f"  MISSING {skill_path}/SKILL.md", file=sys.stderr)
                sys.exit(1)

            dst.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(src, dst)
            print(f"  {skill_path} -> skills/{skill_name}/")
            synced += 1

        return synced


def main():
    cfg = load_config()
    total = 0

    for section in cfg.sections():
        url = cfg.get(section, "url")
        ref = cfg.get(section, "ref", fallback="main")
        skills_raw = cfg.get(section, "skills", fallback="")
        skill_paths = [s.strip() for s in skills_raw.strip().splitlines() if s.strip()]

        if not skill_paths:
            print(f"[{section}] No skills listed, skipping.")
            continue

        total += sync_marketplace(section, url, ref, skill_paths)

    all_skills = sorted(d.name for d in SKILLS_DIR.iterdir() if d.is_dir())
    native = sorted(s for s in all_skills if s in NATIVE_SKILLS)
    vendored = sorted(s for s in all_skills if s not in NATIVE_SKILLS)

    print(f"\n--- Build complete ---")
    print(f"Native:   {', '.join(native)} ({len(native)})")
    print(f"Vendored: {', '.join(vendored)} ({len(vendored)})")
    print(f"Total:    {len(all_skills)} skills")


if __name__ == "__main__":
    main()
