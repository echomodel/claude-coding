{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(tests/**)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ensure-test-skill.sh"
          },
          {
            "type": "command",
            "if": "Write(tests/**)",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ensure-test-skill.sh"
          }
        ]
      }
    ]
  }
}
